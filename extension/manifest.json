{
  "manifest_version": 3,
  "name": "X AI Reply Assistant",
  "version": "0.4.1",
  "description": "在 X 回复框旁生成多种风格的 AI 回复候选，由用户确认后发送。",
  "permissions": ["storage"],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://xleave.59et.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "X AI Reply Assistant",
    "default_popup": "popup.html"
  }
}
