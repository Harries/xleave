# 用户自带 AI Key（BYO），服务器不再用统一 Key 代付。
# OPENAI_API_KEY 不再用于 /api/replies；仅在需要时保留。
OPENAI_MODEL=gpt-5.4-mini

# 用户中心必需：用于加密用户 AI Key（AES-256-GCM）与签名登录会话。
# 生成方式：openssl rand -hex 32
XLEAVE_SECRET_KEY=replace-with-openssl-rand-hex-32

# 管理后台密钥（/admin）。
XLEAVE_ADMIN_TOKEN=replace-with-a-separate-long-admin-secret

XLEAVE_PUBLIC_ORIGIN=https://xleave.59et.com
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# 旧版环境变量用户，作为迁移兜底（可留空）。
XLEAVE_USERS=[{"id":"your-user-id","token":"replace-with-a-long-random-token","allowedIps":["127.0.0.1","::1"]}]
PORT=8787
